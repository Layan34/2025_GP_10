  - m_Id: 262138974523392
    m_Localized: "- \u0627\u0636\u063A\u0637 \u0632\u0631 \u0627\u0644\u0645\u0633\u0627\u0641\u0629
      \u0641\u0642\u0637 \u0639\u0646\u062F\u0645\u0627 \u064A\u0638\u0647\u0631
      \u0627\u0644\u0645\u0631\u0628\u0639 \u0641\u064A \u0627\u0644\u0623\u0639\u0644\u0649.\n\n-
      \u0625\u0630\u0627 \u0638\u0647\u0631 \u0641\u064A \u0627\u0644\u0623\u0633\u0641\u0644\u060C
      \u0644\u0627 \u062A\u0636\u063A\u0637.\n\n- \u062D\u0627\u0648\u0644 \u0623\u0646
      \u062A\u0643\u0648\u0646 \u0633\u0631\u064A\u0639\u064B\u0627 \u0648\u062F\u0642\u064A\u0642\u064B\u0627.\n\n-
      \u0627\u0633\u062A\u0645\u0631 \u062D\u062A\u0649 \u062A\u0646\u062A\u0647\u064A
      \u0627\u0644\u0645\u0647\u0645\u0629."
