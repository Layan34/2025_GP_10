    m_Localized: "\u0627\u062E\u062A\u0627\u0631 \u0644\u0639\u0628\u062A\u0643 "
    m_Metadata:
      m_Items: []
  - m_Id: 507489136496640
    m_Localized: "- \u0627\u0633\u062A\u062E\u062F\u0645 \u0645\u0641\u0627\u062A\u064A\u062D
      \u0627\u0644\u0623\u0633\u0647\u0645 \u0644\u062A\u062D\u0631\u064A\u0643 \u0627\u0644\u0637\u0627\u0626\u0631\u0629
      \u0644\u0644\u0623\u0639\u0644\u0649 \u0648\u0627\u0644\u0623\u0633\u0641\u0644.\r\n\n-
      \u0645\u0631\u0651 \u0645\u0646 \u062E\u0644\u0627\u0644 \u0627\u0644\u062D\u0644\u0642\u0627\u062A
      \u0644\u0643\u0633\u0628 \u0627\u0644\u0646\u0642\u0627\u0637.\r\n\n- \u062A\u062C\u0646\u0628
      \u0627\u0644\u0642\u0646\u0627\u0628\u0644 \u062D\u062A\u0649 \u0644\u0627
      \u062A\u0641\u0642\u062F \u0627\u0644\u0642\u0644\u0648\u0628.\r\n\n- \u062D\u0627\u0641\u0638
      \u0639\u0644\u0649 \u062A\u0631\u0643\u064A\u0632\u0643 \u0648\u0627\u0633\u062A\u0645\u0631
      \u0641\u064A \u0627\u0644\u0637\u064A\u0631\u0627\u0646 \u0644\u062A\u062D\u0642\u064A\u0642
      \u0646\u062A\u064A\u062C\u0629 \u0623\u0639\u0644\u0649."
    m_Metadata:
      m_Items: []
  - m_Id: 508068218884096
    m_Localized: "\u062A\u0639\u0644\u064A\u0645\u0627\u062A \u0627\u0644\u0644\u0639\u0628\u0629"
