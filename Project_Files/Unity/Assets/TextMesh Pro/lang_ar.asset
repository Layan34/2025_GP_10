  - m_Id: 508016545058816
    m_Localized: "- \u0639\u0646\u062F\u0643 \u062B\u0627\u0646\u064A\u062A\u064A\u0646
      \u0644\u0644\u0631\u062F \u0643\u0644 \u0645\u0631\u0629 \u064A\u0638\u0647\u0631
      \u0641\u064A\u0647\u0627 \u0627\u0644\u0641\u0646\u062C\u0627\u0644.\r\n\n-
      \u0627\u0636\u063A\u0637 \u0632\u0631 \u0627\u0644\u0645\u0633\u0627\u0641\u0629
      \u0641\u0642\u0637 \u0625\u0630\u0627 \u0643\u0627\u0646 \u0627\u0644\u0635\u0642\u0631
      \u0641\u0648\u0642 \u0627\u0644\u0639\u0644\u0627\u0645\u0629.\r\n\n- \u0625\u0630\u0627
      \u0643\u0627\u0646 \u0627\u0644\u0635\u0642\u0631 \u062A\u062D\u062A \u0627\u0644\u0639\u0644\u0627\u0645\u0629\u060C
      \u0644\u0627 \u062A\u0636\u063A\u0637 \u0623\u064A \u0634\u064A\u0621\u060C
      \u0644\u0623\u0646\u0643 \u0628\u062A\u062E\u0633\u0631 \u0642\u0644\u0628.\r\n\n-
      \u062D\u0627\u0641\u0638 \u0639\u0644\u0649 \u062A\u0631\u0643\u064A\u0632\u0643
      \u0648\u062E\u0644\u0643 \u0645\u062D\u0627\u0641\u0638 \u0639\u0644\u0649
      \u0642\u0644\u0648\u0628\u0643 \u0639\u0634\u0627\u0646 \u062A\u062D\u0642\u0642
      \u0646\u062A\u064A\u062C\u0629 \u0623\u0639\u0644\u0649.\r\n"
