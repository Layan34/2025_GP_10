  - m_Id: 264224038539264
    m_Localized: "TUTORIAL COMPLETED \nWELL DONE!"
    m_Metadata:
      m_Items: []
  - m_Id: 266187971055616
    m_Localized: Play
    m_Metadata:
      m_Items: []
  - m_Id: 505462452998144
    m_Localized: 'Choose your game '
    m_Metadata:
      m_Items: []
  - m_Id: 507489136496640
    m_Localized: '- Use the arrow keys to move the hot air balloon up and down.


      -
      Fly through the rings to earn points.


      - Avoid the bombs to prevent
      losing hearts.


      - Stay focused and keep flying to achieve a higher score.

'
    m_Metadata:
      m_Items: []
  - m_Id: 508068218884096
    m_Localized: Game Instructions
    m_Metadata:
      m_Items: []
  - m_Id: 508800468865024
    m_Localized: Skip
    m_Metadata:
      m_Items: []
  - m_Id: 508016545058816
    m_Localized: '- You have a 2-second window to respond each time the falcon appears.


      -
      Press SPACE only when the falcon is above the cross.


      - Do not press
      anything if the falcon is below the cross, doing so will cost you one heart.


      -
      Stay focused and keep your hearts to reach a higher score.

'
    m_Metadata:
      m_Items: []
