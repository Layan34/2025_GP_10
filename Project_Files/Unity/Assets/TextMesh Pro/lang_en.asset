  - m_Id: 261705107329024
    m_Localized: Tutorial
    m_Metadata:
      m_Items: []
  - m_Id: 261892181676032
    m_Localized: Instructions
    m_Metadata:
      m_Items: []
  - m_Id: 262138974523392
    m_Localized: "- Press space only when the square appears at the top.\n\n- If
      it appears at the bottom, don\u2019t press.\n\n- Try to stay quick and accurate.\n\n-
      Continue until the task ends."
    m_Metadata:
      m_Items: []
  - m_Id: 262706287693824
    m_Localized: BE READY
    m_Metadata:
      m_Items: []
